{
  "campaign_name": "normal_only_openloop_smoke_milestone1",
  "endpoint": {
    "url": "operator-fill-actual-yolo-endpoint",
    "method": "POST",
    "payload_field": "file"
  },
  "node_gpu_identity": {
    "node_name": "operator-fill-node-name",
    "gpu_uuid": "operator-fill-gpu-uuid",
    "gpu_model": "operator-fill-gpu-model"
  },
  "container_image": "operator-fill-yolo-container-image",
  "yolo_model": "operator-fill-yolo-model",
  "replicates": 1,
  "normal_live_smoke": {
    "target_rps": 0.5,
    "duration_s": 60,
    "max_inflight": 4,
    "timeout_s": 10,
    "payload_mix": ["operator-fill-image-list.txt"],
    "description": "Milestone 1 data-chain smoke only. No calibration sweep, fan control, CoolerControl, cooling intervention, Kubernetes control, or GPU stress."
  },
  "calibration": {
    "candidate_offered_rps": [],
    "duration_s": 60,
    "max_inflight": 4,
    "timeout_s": 10,
    "payload_mix": ["operator-fill-image-list.txt"],
    "decision_policy": "Not used in Milestone 1. Run calibration only after normal-only smoke passes."
  },
  "workload_profiles": {
    "smoke_low": {
      "target_rps": 0.5,
      "duration_s": 60,
      "max_inflight": 4,
      "payload_mix": ["operator-fill-image-list.txt"],
      "purpose": "Conservative normal-only smoke offered demand."
    }
  },
  "cooling_conditions": {
    "normal_cooling": {
      "description": "No fan intervention; normal system cooling policy.",
      "fan_control_allowed": false,
      "primary_control": "none"
    }
  },
  "background_workload": {
    "enabled": false,
    "profile": "none",
    "allocation": "none"
  },
  "safety": {
    "operator_max_gpu_temp_c": null,
    "restore_mode": "GPU_DEFAULT",
    "require_telemetry_freshness_s": 5,
    "abort_on_service_total_failure_s": 30,
    "timeout_rate_abort_fraction": 0.2,
    "error_rate_abort_fraction": 0.2,
    "max_inflight_saturation_abort_fraction": 0.05,
    "abort_on_control_command_failure": true,
    "abort_on_missing_gpu_telemetry": true
  },
  "telemetry_runtime": {
    "namespace": "intent-lab",
    "node": "operator-fill-node-name",
    "nvidia_smi_ssh_alias": "operator-fill-worker-ssh-alias",
    "mode": "fast",
    "vm_agg_interval_s": 1.0,
    "post_client_wait_s": 1,
    "tail_seconds": 5,
    "vm_url": "",
    "netdata_url": "",
    "netdata_child_url": "",
    "netdata_parent_base_url": "",
    "node_exporter_instance": ""
  },
  "telemetry_sources": {
    "open_loop_client_log": true,
    "open_loop_arrival_1s_summary": true,
    "open_loop_completion_1s_summary": true,
    "vm_aggregator_timeseries": true,
    "vm_query_samples_with_sample_age": true,
    "nvidia_smi_gpu_1s": true,
    "worker_thermal_telemetry": false,
    "control_event_log": false
  },
  "analysis_policy": {
    "milestone": "Milestone 1: normal-only smoke data-chain validation",
    "do_not_run": [
      "--calibrate-normal",
      "--run-campaign",
      "fan control",
      "CoolerControl",
      "Kubernetes scale/restart/delete",
      "long GPU stress"
    ]
  }
}
