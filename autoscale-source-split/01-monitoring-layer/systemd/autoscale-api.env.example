# Copy this file to `systemd/autoscale-api.env` and fill in real values.
# This file is loaded by `systemd/autoscale-api.service`.
# Suggested workflow:
# 1. Copy `monitoring-runtime.host.env.example` to `monitoring-runtime.host.env`
# 2. Reuse the same VM_URL / NETDATA_* values here
# IMPORTANT: copying this file alone is not enough. You must replace every `<control-plane-ip>` placeholder with the real host-side endpoints for this machine.
# If you leave the placeholders unchanged, `autoscale_api` may still start, but `/api/v1/full-metrics` can fail for all k8s nodes while RFSoC/AP nodes still look healthy.

AUTOSCALE_API_TOKEN=replace-with-a-long-random-token
AUTOSCALE_API_HOST=0.0.0.0
AUTOSCALE_API_PORT=8000

VM_URL=http://<control-plane-ip>:31888
NETDATA_PARENT_BASE_URL=http://<control-plane-ip>:32163
NETDATA_URL=http://<control-plane-ip>:32163
NETDATA_CHILD_URL=http://<control-plane-ip>:32163
KSM_URL=http://<control-plane-ip>:32080
PRE6G_WORKLOAD_QUERY_WINDOW_SECONDS=3

# Optional: Fan-Cycle / YOLO demo runtime for `03-shared-api-dashboard`
# These defaults match the currently validated lab environment on `icclz2` + `icclz1`.
PRE6G_EXPERIMENT_NAMESPACE=intent-lab
PRE6G_EXPERIMENT_NODE_NAME=icclz1
PRE6G_EXPERIMENT_NODE_SSH=icclz1-gpu
PRE6G_EXPERIMENT_FOCUS_DEPLOY=yolo26n-focus
PRE6G_EXPERIMENT_BG_DEPLOY=yolo26n-bg-1
PRE6G_EXPERIMENT_MEAS_SVC_NAME=
PRE6G_EXPERIMENT_TARGET_MODE=pod
PRE6G_EXPERIMENT_WORKER_REPO=/home/icclz1/gpu-tempctl-lab
PRE6G_EXPERIMENT_WORKER_VENV=/home/icclz1/gpu-tempctl-1080ti/bin/activate
PRE6G_EXPERIMENT_CC_PASSWORD=replace-with-coolercontrol-password
PRE6G_EXPERIMENT_REPEAT=10
PRE6G_EXPERIMENT_TIMEOUT_SEC=30
PRE6G_EXPERIMENT_DURATION_SEC=86400
PRE6G_EXPERIMENT_BG_SIZE=4096
PRE6G_EXPERIMENT_BG_DUTY=1.0
PRE6G_EXPERIMENT_BG_PERIOD_MS=100
PRE6G_EXPERIMENT_CYCLES=1
PRE6G_EXPERIMENT_NORMAL_HOLD_SECONDS=300
PRE6G_EXPERIMENT_FAULT_HOLD_SECONDS=300
PRE6G_EXPERIMENT_RECOVERY_STABLE_SECONDS=60
PRE6G_EXPERIMENT_RECOVERY_MAX_SECONDS=300
PRE6G_EXPERIMENT_WORKLOAD_HEADROOM_SECONDS=120
PRE6G_EXPERIMENT_FIXED_FAN_PCT=5
PRE6G_EXPERIMENT_VM_AGG_INTERVAL=1.0
