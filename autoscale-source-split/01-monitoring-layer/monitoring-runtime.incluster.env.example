# Copy to `monitoring-runtime.incluster.env` and edit only if namespaces/service names differ.
# This profile is for Jobs/Pods running INSIDE the cluster.

MONITORING_NS=monitoring
QUERY_NS=intent-lab
AUTOSCALE_API_HOST=0.0.0.0
AUTOSCALE_API_PORT=8000

VM_URL="http://vm-victoria-metrics-single-server.monitoring.svc:8428"
NETDATA_URL="http://netdata.netdata.svc:19999"
NETDATA_CHILD_URL="${NETDATA_URL}"
NETDATA_PARENT_BASE_URL="${NETDATA_URL}"
