# Copy to `monitoring-runtime.host.env` and edit for the current environment.
# This profile is for tools/services running OUTSIDE the cluster, e.g.
# - run_vm_aggregator_once.sh launched from a host shell
# - autoscale-api.service running via systemd on a host

CONTROL_PLANE_IP=140.113.179.9
VM_NODEPORT=31888
NETDATA_NODEPORT=32163
MONITORING_NS=monitoring
QUERY_NS=intent-lab
AUTOSCALE_API_HOST=0.0.0.0
AUTOSCALE_API_PORT=8000

VM_URL="http://${CONTROL_PLANE_IP}:${VM_NODEPORT}"
NETDATA_URL="http://${CONTROL_PLANE_IP}:${NETDATA_NODEPORT}"
NETDATA_CHILD_URL="${NETDATA_URL}"
NETDATA_PARENT_BASE_URL="${NETDATA_URL}"
