FROM node:22-alpine AS build

WORKDIR /app

COPY autoscale-source-split/03-shared-api-dashboard/cluster-dashboard/package.json /app/package.json
COPY autoscale-source-split/03-shared-api-dashboard/cluster-dashboard/package-lock.json /app/package-lock.json
RUN npm ci

COPY autoscale-source-split/03-shared-api-dashboard/cluster-dashboard /app
RUN npm run build

FROM nginx:1.29-alpine

COPY autoscale-source-split/03-shared-api-dashboard/cluster-dashboard/nginx/default.conf /etc/nginx/conf.d/default.conf
COPY autoscale-source-split/03-shared-api-dashboard/cluster-dashboard/docker-entrypoint.d/40-write-env-config.sh /docker-entrypoint.d/40-write-env-config.sh
COPY --from=build /app/dist /usr/share/nginx/html

RUN chmod +x /docker-entrypoint.d/40-write-env-config.sh

EXPOSE 8080
